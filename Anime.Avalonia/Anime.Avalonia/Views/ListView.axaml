<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Anime.Avalonia.ViewModels"
             x:Class="Anime.Avalonia.Views.ListView"
             x:DataType="vm:ListViewModel">

	<Grid RowDefinitions="Auto, *">

		<StackPanel Grid.Row="0" Margin="12 12 12 4">
			<TextBlock Text="我的列表"
                       FontSize="26"
                       FontWeight="Bold"/>
			<TextBlock Text="{Binding Status}"
                       FontSize="12"
                       Foreground="Gray"
                       Margin="0,4,0,12"/>
		</StackPanel>

		<ScrollViewer Grid.Row="1">
			<ItemsControl ItemsSource="{Binding Animes}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Columns="2"
                                     Margin="6"
                                     HorizontalAlignment="Stretch"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Margin="6" Padding="16" CornerRadius="12"
                                Background="{DynamicResource SystemAccentColorLight3}"
                                PointerPressed="OnItemPointerPressed"
                                ClipToBounds="True">
							<TextBlock Text="{Binding Title}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

	</Grid>
</UserControl>