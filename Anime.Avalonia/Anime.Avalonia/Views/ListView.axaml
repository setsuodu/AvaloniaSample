<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Anime.Avalonia.ViewModels"
             x:Class="Anime.Avalonia.Views.ListView"
             x:DataType="vm:ListViewModel">

	<Grid RowDefinitions="Auto, Auto, *" Margin="12">

		<TextBlock Grid.Row="0"
                   Text="我的列表"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0 0 0 12"/>

		<StackPanel Grid.Row="1" Margin="0 0 0 12">
			<TextBlock Text="{Binding Status}"
                       FontSize="14"
                       Foreground="#007ACC"
                       Margin="0 4 0 0"/>
		</StackPanel>

		<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">

			<ItemsControl ItemsSource="{Binding Animes}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Columns="2"
                                     HorizontalAlignment="Stretch"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Margin="6"
                                Width="172"
                                Height="258"
                                CornerRadius="12"
                                Background="{DynamicResource SystemAccentColorLight3}"
                                PointerPressed="OnItemPointerPressed"
                                ClipToBounds="True">

							<Grid RowDefinitions="*, Auto" Margin="12">

								<Panel Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
									<PathIcon Data="{StaticResource ImageRegular}" Opacity="0.15" Width="36" Height="36"/>
								</Panel>

								<TextBlock Grid.Row="1"
                                           Text="{Binding Title}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,8,0,0"/>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

		</ScrollViewer>
	</Grid>
</UserControl>