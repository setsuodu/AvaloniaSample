<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MyXPlatApp.ViewModels"
             x:Class="MyXPlatApp.Views.ListView"
             x:DataType="vm:ListViewModel">
	<DockPanel>
		<TextBlock DockPanel.Dock="Top" Text="我的列表" FontSize="20" Margin="15" FontWeight="Bold"/>
		<ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border Margin="5" Padding="15" CornerRadius="8" Background="{DynamicResource SystemAccentColorLight3}">
						<TextBlock Text="{Binding Title}" FontSize="16" VerticalAlignment="Center"/>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</DockPanel>
</UserControl>