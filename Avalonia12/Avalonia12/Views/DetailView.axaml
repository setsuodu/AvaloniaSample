<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Avalonia12.ViewModels"
             x:Class="Avalonia12.Views.DetailView"
             x:DataType="vm:DetailViewModel">
	<Border Padding="20">
		<StackPanel Spacing="15">
			<Button Command="{Binding BackCommand}" Content="← 返回列表" Padding="10,5"/>

			<Border Background="#22000000"
					CornerRadius="12"
					Padding="20">
				<StackPanel Spacing="10">
					<TextBlock Text="{Binding Item.Title}" FontSize="22" FontWeight="Bold"/>
					<Separator Height="1" Background="#CCCCCC"/>
					<TextBlock Text="{Binding Item.Description}" FontSize="16" TextWrapping="Wrap"/>
				</StackPanel>
			</Border>
		</StackPanel>
	</Border>
</UserControl>